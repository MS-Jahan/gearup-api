{
  "openapi": "3.0.0",
  "info": {
    "title": "GearUp API",
    "version": "1.0.0",
    "description": "Sports and outdoor gear rental service backend API"
  },
  "servers": [
    {
      "url": "/",
      "description": "Current host"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/reviews": {
      "post": {
        "tags": [
          "Reviews"
        ],
        "summary": "Leave a review after gear is returned"
      }
    },
    "/api/reviews/gear/{gearId}": {
      "get": {
        "tags": [
          "Reviews"
        ],
        "summary": "Get reviews for a gear item"
      }
    },
    "/api/rentals": {
      "post": {
        "tags": [
          "Rentals"
        ],
        "summary": "Create a rental order"
      },
      "get": {
        "tags": [
          "Rentals"
        ],
        "summary": "List current customer's rental orders (paginated)",
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 10
            }
          }
        ]
      }
    },
    "/api/rentals/{id}": {
      "get": {
        "tags": [
          "Rentals"
        ],
        "summary": "Get rental order details"
      }
    },
    "/api/rentals/{id}/cancel": {
      "patch": {
        "tags": [
          "Rentals"
        ],
        "summary": "Cancel a rental order (PLACED or CONFIRMED only)"
      }
    },
    "/api/provider/gear": {
      "post": {
        "tags": [
          "Provider"
        ],
        "summary": "Add gear to inventory"
      }
    },
    "/api/provider/gear/{id}": {
      "put": {
        "tags": [
          "Provider"
        ],
        "summary": "Update a gear listing"
      },
      "delete": {
        "tags": [
          "Provider"
        ],
        "summary": "Remove gear from inventory"
      }
    },
    "/api/provider/orders": {
      "get": {
        "tags": [
          "Provider"
        ],
        "summary": "View incoming rental orders"
      }
    },
    "/api/provider/orders/{id}": {
      "patch": {
        "tags": [
          "Provider"
        ],
        "summary": "Update rental order status"
      }
    },
    "/api/profile": {
      "get": {
        "tags": [
          "Profile"
        ],
        "summary": "Get current user profile"
      },
      "patch": {
        "tags": [
          "Profile"
        ],
        "summary": "Update current user profile"
      }
    },
    "/api/payments/pay": {
      "get": {
        "tags": [
          "Payments"
        ],
        "summary": "Embedded Stripe Checkout payment page"
      }
    },
    "/api/payments/success": {
      "get": {
        "tags": [
          "Payments"
        ],
        "summary": "Stripe Checkout success redirect page"
      }
    },
    "/api/payments/cancel": {
      "get": {
        "tags": [
          "Payments"
        ],
        "summary": "Stripe Checkout cancel redirect page"
      }
    },
    "/api/payments/create": {
      "post": {
        "tags": [
          "Payments"
        ],
        "summary": "Create Stripe Checkout session for rental order",
        "description": "Returns a payment page `url` on this API — open it in a browser to pay via Stripe Checkout.\nAfter payment, Stripe calls `/api/payments/webhook` and the order is marked PAID.\n"
      }
    },
    "/api/payments/confirm": {
      "post": {
        "tags": [
          "Payments"
        ],
        "summary": "Confirm payment manually (fallback if webhook is delayed)"
      }
    },
    "/api/payments": {
      "get": {
        "tags": [
          "Payments"
        ],
        "summary": "Get customer payment history"
      }
    },
    "/api/payments/{id}": {
      "get": {
        "tags": [
          "Payments"
        ],
        "summary": "Get payment details by ID"
      }
    },
    "/api/gear": {
      "get": {
        "tags": [
          "Gear"
        ],
        "summary": "Browse gear with filters"
      }
    },
    "/api/gear/{id}": {
      "get": {
        "tags": [
          "Gear"
        ],
        "summary": "Get gear details"
      }
    },
    "/api/categories": {
      "get": {
        "tags": [
          "Categories"
        ],
        "summary": "List all gear categories"
      },
      "post": {
        "tags": [
          "Categories"
        ],
        "summary": "Create a gear category (admin only)"
      }
    },
    "/api/categories/{id}": {
      "patch": {
        "tags": [
          "Categories"
        ],
        "summary": "Update a gear category (admin only)"
      },
      "delete": {
        "tags": [
          "Categories"
        ],
        "summary": "Delete an empty gear category (admin only)"
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Register a new customer or provider"
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Login and get JWT token"
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Get current authenticated user"
      }
    },
    "/api/admin/users": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "List all users"
      }
    },
    "/api/admin/users/{id}": {
      "patch": {
        "tags": [
          "Admin"
        ],
        "summary": "Update user status (suspend or activate)"
      }
    },
    "/api/admin/gear": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "List all gear listings"
      }
    },
    "/api/admin/rentals": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "List all rental orders"
      }
    }
  },
  "tags": []
}