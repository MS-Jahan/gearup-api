generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum GearStatus {
  AVAILABLE
  UNAVAILABLE
  MAINTENANCE
}

enum RentalStatus {
  PLACED
  CONFIRMED
  CANCELLED
  PAID
  PICKED_UP
  RETURNED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  SSLCOMMERZ
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String
  phone     String?
  role      Role
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  gearItems       GearItem[]
  customerOrders  RentalOrder[] @relation("CustomerOrders")
  providerOrders  RentalOrder[] @relation("ProviderOrders")
  payments        Payment[]
  reviews         Review[]
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  createdAt   DateTime   @default(now())

  gearItems GearItem[]
}

model GearItem {
  id             String     @id @default(cuid())
  providerId     String
  categoryId     String
  name           String
  brand          String
  description    String
  pricePerDay    Decimal    @db.Decimal(10, 2)
  stock          Int        @default(1)
  specifications Json?
  status         GearStatus @default(AVAILABLE)
  images         String[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  provider   User              @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category   Category          @relation(fields: [categoryId], references: [id])
  orderItems RentalOrderItem[]
  reviews    Review[]

  @@index([categoryId])
  @@index([brand])
  @@index([status])
}

model RentalOrder {
  id          String       @id @default(cuid())
  customerId  String
  providerId  String
  startDate   DateTime
  endDate     DateTime
  totalAmount Decimal      @db.Decimal(10, 2)
  status      RentalStatus @default(PLACED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  customer   User              @relation("CustomerOrders", fields: [customerId], references: [id])
  provider   User              @relation("ProviderOrders", fields: [providerId], references: [id])
  items      RentalOrderItem[]
  payment    Payment?
  review     Review?

  @@index([customerId])
  @@index([providerId])
  @@index([status])
}

model RentalOrderItem {
  id            String  @id @default(cuid())
  rentalOrderId String
  gearItemId    String
  quantity      Int
  pricePerDay   Decimal @db.Decimal(10, 2)

  rentalOrder RentalOrder @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade)
  gearItem    GearItem    @relation(fields: [gearItemId], references: [id])
}

model Payment {
  id                    String          @id @default(cuid())
  rentalOrderId         String          @unique
  customerId            String
  amount                Decimal         @db.Decimal(10, 2)
  provider              PaymentProvider @default(STRIPE)
  stripePaymentIntentId String?
  status                PaymentStatus   @default(PENDING)
  paidAt                DateTime?
  createdAt             DateTime        @default(now())

  rentalOrder RentalOrder @relation(fields: [rentalOrderId], references: [id])
  customer    User        @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
}

model Review {
  id            String   @id @default(cuid())
  customerId    String
  gearItemId    String
  rentalOrderId String   @unique
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  customer    User        @relation(fields: [customerId], references: [id])
  gearItem    GearItem    @relation(fields: [gearItemId], references: [id])
  rentalOrder RentalOrder @relation(fields: [rentalOrderId], references: [id])

  @@index([gearItemId])
}
